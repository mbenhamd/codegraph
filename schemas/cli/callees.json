{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codegraph.papersflow.ai/schemas/cli/callees.json",
  "title": "codegraph callees --json",
  "allOf": [{ "$ref": "envelope.json" }],
  "type": "object",
  "required": ["schemaVersion", "tool", "symbol", "callees"],
  "additionalProperties": true,
  "properties": {
    "tool": { "const": "callees" },
    "symbol": { "type": "string" },
    "notFound": {
      "type": "boolean",
      "description": "Set to true when the symbol does not exist in the index. `callees` is then [] and consumers can distinguish 'symbol absent' from 'symbol exists but calls nothing'."
    },
    "callees": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "filePath"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "filePath": { "type": "string" },
          "startLine": { "type": ["integer", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "resolvedBy": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
