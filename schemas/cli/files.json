{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codegraph.papersflow.ai/schemas/cli/files.json",
  "title": "codegraph files --json",
  "allOf": [{ "$ref": "envelope.json" }],
  "type": "object",
  "required": ["schemaVersion", "tool", "files"],
  "additionalProperties": true,
  "properties": {
    "tool": { "const": "files" },
    "reason": {
      "type": "string",
      "enum": ["not_indexed", "no_matches"],
      "description": "Set when `files` is []: `not_indexed` if the project IS initialized but the file index is empty (usually requires running `codegraph index`), `no_matches` if filters left no rows. A completely uninitialized project remains a plain-text error path with process.exit(1)."
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "language", "nodeCount", "size"],
        "properties": {
          "path": { "type": "string" },
          "language": { "type": "string" },
          "nodeCount": { "type": "integer", "minimum": 0 },
          "size": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  }
}
