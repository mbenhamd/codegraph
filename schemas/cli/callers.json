{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codegraph.papersflow.ai/schemas/cli/callers.json",
  "title": "codegraph callers --json",
  "allOf": [{ "$ref": "envelope.json" }],
  "type": "object",
  "required": ["schemaVersion", "tool", "symbol", "callers"],
  "additionalProperties": true,
  "properties": {
    "tool": { "const": "callers" },
    "symbol": { "type": "string" },
    "notFound": {
      "type": "boolean",
      "description": "Set to true when the symbol does not exist in the index. `callers` is then [] and consumers can distinguish 'symbol absent' from 'symbol exists but has no callers'."
    },
    "callers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "filePath"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "filePath": { "type": "string" },
          "startLine": { "type": ["integer", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "resolvedBy": { "type": "string" },
          "edgeId": {
            "type": "integer",
            "minimum": 1,
            "description": "Edge primary key (PF-693). Index-local — resets on rebuild — pasteable into `codegraph explain <edgeId>` for the same index."
          }
        },
        "additionalProperties": true
      }
    }
  }
}
